# Required: absolute path to the existing Obsidian riji directory. It is never copied.
RIJI_JOURNAL_ROOT=/absolute/path/to/your/Obsidian/riji

# Optional: local runtime state, outside this Git repository.
# Default: ~/.local/share/riji-agent (or the platform equivalent)
# RIJI_DATA_DIR=/absolute/path/to/riji-agent-data
# RIJI_DATABASE_PATH=/absolute/path/to/riji-agent-data/riji-agent.sqlite3

# Required: cloud model credential. Keep this file local.
DEEPSEEK_API_KEY=replace-me
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Required: only these Feishu open IDs may use private-chat journal tools.
# Separate multiple IDs with commas. Group chats are denied by design.
RIJI_ALLOWED_FEISHU_USER_IDS=ou_replace_me

# Required: shared credential for the local Hermes-to-riji-agent tool boundary.
HERMES_SHARED_SECRET=replace-with-a-long-random-secret
HERMES_BASE_URL=http://127.0.0.1:3000

# The application listener is intentionally fixed to 127.0.0.1.
RIJI_PORT=8765
