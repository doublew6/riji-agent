# Required: absolute path to the existing Obsidian riji directory. It is never copied.
RIJI_JOURNAL_ROOT=/absolute/path/to/your/Obsidian/riji

# Optional: local runtime state, outside this Git repository.
# Default: ~/.local/share/riji-agent (or the platform equivalent)
# RIJI_DATA_DIR=/absolute/path/to/riji-agent-data
# RIJI_DATABASE_PATH=/absolute/path/to/riji-agent-data/riji-agent.sqlite3

# Required: cloud model credential. Keep this file local.
RIJI_IM_PROVIDER=feishu
RIJI_AGENT_RUNTIME=hermes
RIJI_MODEL_PROVIDER=deepseek
DEEPSEEK_API_KEY=replace-me
DEEPSEEK_BASE_URL=https://api.deepseek.com
# Optional: deepseek-reasoner (default) or deepseek-chat.
# DEEPSEEK_MODEL=deepseek-reasoner

# Required: only these Feishu open IDs may use private-chat journal tools.
# Separate multiple IDs with commas. Group chats are denied by design.
RIJI_ALLOWED_FEISHU_USER_IDS=ou_replace_me

# Required: shared credential for the local Hermes-to-riji-agent tool boundary.
HERMES_SHARED_SECRET=replace-with-a-long-random-secret
HERMES_BASE_URL=http://127.0.0.1:3000

# Hermes-side Feishu bridge (src/riji_agent/integrations/hermes_bridge.py).
# Where the bridge POSTs each Feishu private message; the secret above must
# match riji-agent's HERMES_SHARED_SECRET. Default below; uncomment to override.
# RIJI_AGENT_URL=http://127.0.0.1:8765/hermes/messages
# RIJI_AGENT_TIMEOUT_SECONDS=240

# The application listener is intentionally fixed to 127.0.0.1.
RIJI_PORT=8765

# Optional: background journal indexing.
# RIJI_INDEX_SCHEDULE_ENABLED=true        # periodic incremental indexing while running
# RIJI_INDEX_INTERVAL_SECONDS=600         # how often to re-index (default 10 min)
# RIJI_INDEX_STARTUP_TIMEOUT_SECONDS=10   # max seconds to wait for the first index at startup
# RIJI_INDEX_FILE_TIMEOUT_SECONDS=5       # per-file read budget; a slow/cold (iCloud) file is skipped past this

# Optional: enable local hybrid keyword+semantic search (embeddings stay on-device).
# RIJI_SEMANTIC_SEARCH=false
